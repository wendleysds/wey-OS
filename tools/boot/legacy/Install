#!/bin/bash

if [ -z "$1" ]; then
	echo "Usage: $0 <target device/iso file>"
	exit 1
fi

make -C tools/boot/legacy || { echo "Build failed"; exit 1; }

# copy the bootloader to the first sector of the target
BOOTLOADER="tools/boot/legacy/bootloader.bin"
if [ ! -f "$BOOTLOADER" ]; then
	echo "Bootloader not found!"
	exit 1
fi
	dd if="$BOOTLOADER" of="$1" bs=512 count=1 conv=notrunc || { echo "Failed to write bootloader"; exit 1; }
	echo "Bootloader installed successfully."
	exit 0
end
